{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projectName",
    "projectType",
    "summary",
    "mainFlow",
    "components",
    "criticalTopics",
    "questions"
  ],
  "properties": {
    "projectName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "projectType": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1200
    },
    "mainFlow": {
      "type": "array",
      "minItems": 2,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 300
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "responsibility",
          "paths"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "kind": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "responsibility": {
            "type": "string",
            "minLength": 5,
            "maxLength": 500
          },
          "paths": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            }
          }
        }
      }
    },
    "criticalTopics": {
      "type": "array",
      "minItems": 2,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 160
      }
    },
    "questions": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "prompt",
          "learningGoal",
          "expectedKeyPoints",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
          },
          "prompt": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500
          },
          "learningGoal": {
            "type": "string",
            "minLength": 3,
            "maxLength": 240
          },
          "expectedKeyPoints": {
            "type": "array",
            "minItems": 2,
            "maxItems": 6,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 2,
              "maxLength": 300
            }
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "path",
                "startLine",
                "endLine",
                "reason"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 300
                },
                "startLine": {
                  "type": "integer",
                  "minimum": 1
                },
                "endLine": {
                  "type": "integer",
                  "minimum": 1
                },
                "reason": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 300
                }
              }
            }
          }
        }
      }
    }
  }
}
