{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "const": "ok"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    }
  },
  "required": ["status", "message"]
}
